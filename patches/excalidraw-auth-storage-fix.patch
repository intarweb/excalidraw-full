diff --git a/excalidraw-app/tests/useAuth.test.ts b/excalidraw-app/tests/useAuth.test.ts
new file mode 100644
index 00000000..6c4583fe
--- /dev/null
+++ b/excalidraw-app/tests/useAuth.test.ts
@@ -0,0 +1,74 @@
+import { renderHook } from "@testing-library/react";
+import { beforeEach, describe, expect, it, vi } from "vitest";
+
+import { useAuth } from "../hooks/useAuth";
+
+// Prove the app-JWT capture + auto-login behavior that makes /api/v2/kv authed:
+//  - valid token  → setUser(...), no redirect
+//  - ?token= in URL → captured into localStorage
+//  - no token      → setUser(null) + redirect to /auth/login (once-guarded)
+//  - expired token → cleared + setUser(null) + redirect
+// (Regression guard for the "empty library / 401 Authorization header required" bug.)
+
+vi.mock("jwt-decode", () => ({
+  jwtDecode: (t: string) => {
+    if (t === "expired") {
+      return { sub: "s", exp: 1 }; // far past
+    }
+    return {
+      sub: "9cdb55c", login: "terafin", email: "j@x", exp: Math.floor(Date.now() / 1000) + 3600,
+    };
+  },
+}));
+
+const setHref = vi.fn();
+
+beforeEach(() => {
+  localStorage.clear();
+  sessionStorage.clear();
+  setHref.mockClear();
+  // jsdom: intercept navigation
+  delete (window as any).location;
+  (window as any).location = { search: "", pathname: "/", href: "",
+    set href(v: string) { setHref(v); } } as any;
+  window.history.replaceState = vi.fn() as any;
+});
+
+describe("useAuth", () => {
+  it("sets the user and does NOT redirect when a valid token is stored", () => {
+    localStorage.setItem("token", "valid");
+    const setUser = vi.fn();
+    renderHook(() => useAuth(setUser));
+    expect(setUser).toHaveBeenCalledWith(expect.objectContaining({ subject: "9cdb55c" }));
+    expect(setHref).not.toHaveBeenCalled();
+  });
+
+  it("captures ?token= from the URL into localStorage", () => {
+    (window as any).location.search = "?token=valid";
+    const setUser = vi.fn();
+    renderHook(() => useAuth(setUser));
+    expect(localStorage.getItem("token")).toBe("valid");
+  });
+
+  it("redirects to /auth/login when there is no token", () => {
+    const setUser = vi.fn();
+    renderHook(() => useAuth(setUser));
+    expect(setUser).toHaveBeenCalledWith(null);
+    expect(setHref).toHaveBeenCalledWith("/auth/login");
+  });
+
+  it("clears an expired token and redirects to /auth/login", () => {
+    localStorage.setItem("token", "expired");
+    const setUser = vi.fn();
+    renderHook(() => useAuth(setUser));
+    expect(localStorage.getItem("token")).toBeNull();
+    expect(setHref).toHaveBeenCalledWith("/auth/login");
+  });
+
+  it("redirects at most once per session (loop guard)", () => {
+    const setUser = vi.fn();
+    renderHook(() => useAuth(setUser));
+    renderHook(() => useAuth(setUser));
+    expect(setHref).toHaveBeenCalledTimes(1);
+  });
+});
